# Copy this file to .env and add your private Gemini API key.
# Never commit the real .env file.
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite
GEMINI_API_KEY=

# Shared only between Docker and the native Windows Bluetooth bridge.
# Replace this value if other devices can reach your computer.
XBLOOM_BRIDGE_TOKEN=replace-with-a-long-random-local-token
